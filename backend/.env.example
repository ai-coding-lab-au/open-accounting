# Backend configuration. Copy to .env and adjust.

# ---------------------------------------------------------------------------
# DATA_DIR — where SQLite files and attachments live.
#
# Two modes:
#
#   Demo / development (default):
#     DATA_DIR=../data
#     Relative paths are resolved from the repository root, so this creates a
#     data folder next to the clone (for example C:\data when the repo is
#     C:\open-accounting). Convenient for demos; do not put real customer data
#     there.
#
#   Production (real customer data):
#     DATA_DIR=D:\books-data
#     (or any absolute path outside the project tree)
#     Real data is kept outside the project so a coding assistant with a
#     project-only sandbox rule cannot read it. The backend will print a
#     one-line "external DATA_DIR" warning at startup — that's expected.
#
# Tip: keep two .env files (.env.demo and .env.prod) and swap when needed.
# ---------------------------------------------------------------------------
DATA_DIR=../data

# CORS - only allow the Vite dev server origin.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
